{
  "name": "Deny-PublicPaaSEndpoints-Supplemental",
  "type": "Microsoft.Authorization/policySetDefinitions",
  "apiVersion": "2021-06-01",
  "properties": {
    "policyType": "Custom",
    "displayName": "Deny Public Network Access on PaaS - Supplemental",
    "description": "Supplemental initiative covering PaaS services that support Private Link but are NOT included in the ALZ Deny-PublicPaaSEndpoints initiative. All 17 bundled definitions are custom (authored in this repo, not Microsoft built-ins) and live in policies/custom-definitions/. Default effect is Deny, with the standard non-compliance message: 'Private Endpoints Must Be Enabled - No Public Access'.",
    "metadata": {
      "version": "1.0.0",
      "category": "Network",
      "source": "https://github.com/bbabcock1990/Deny-All-Azure-PaaS"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Effect applied uniformly to every bundled custom policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyDefinitionGroups": null,
    "policyDefinitions": [
      {
        "policyDefinitionReferenceId": "Deny-SignalR-Public-Network-Access",
        "policyDefinitionId": "${managementGroupResourceId}/providers/Microsoft.Authorization/policyDefinitions/Deny-SignalR-Public-Network-Access",
        "parameters": { "effect": { "value": "[parameters('effect')]" } },
        "groupNames": []
      },
      {
        "policyDefinitionReferenceId": "Deny-WebPubSub-Public-Network-Access",
